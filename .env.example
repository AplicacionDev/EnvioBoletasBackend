PORT=3500
NODE_ENV=development

# SQL Server
DB_SERVER=
DB_PORT=1433
DB_DATABASE=
DB_USER=
DB_PASSWORD=
# Driver SQL: auto | tedious | msnodesqlv8
# auto: Windows => msnodesqlv8, Linux => tedious
DB_DRIVER=auto
# Solo aplica cuando DB_DRIVER=msnodesqlv8
DB_ODBC_DRIVER=ODBC Driver 18 for SQL Server
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_APP_NAME=EnvioBoletas
PRE_ENVIO_SP=

# SMTP (Office 365)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Microsoft Graph API
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TENANT_ID=
GRAPH_SEND_AS=

# Microsoft Entra ID (SSO / Login de usuarios)
ENTRA_CLIENT_ID=
ENTRA_TENANT_ID=
# Audience esperado por el backend. Si lo dejas vacío, usa api://ENTRA_CLIENT_ID
ENTRA_AUDIENCE=
